{
  "id": "mollie",
  "name": "Mollie",
  "version": "1.0.0",
  "description": "Payments, subscriptions, and billing",
  "icon": "card",
  "profile": "charge",
  "mcp": {
    "command": "sh",
    "args": ["-c", "mcp-remote https://mcp.mollie.com/mcp --header \"Authorization: Bearer $MOLLIE_ACCESS_TOKEN\""]
  },
  "credentials": {
    "fields": [
      { "key": "accessToken", "label": "Access Token", "type": "password", "placeholder": "access_org_..." }
    ],
    "envMapping": { "MOLLIE_ACCESS_TOKEN": "accessToken" }
  },
  "oauth": null,
  "toolGating": {
    "default": {
      "executionMapping": {},
      "staticExecution": { "action_type": "read" }
    },
    "overrides": {
      "CreatePayment": {
        "executionMapping": {
          "amount": "amount",
          "currency": "currency"
        },
        "staticExecution": { "action_type": "charge" }
      },
      "CreatePaymentForCustomer": {
        "executionMapping": {
          "amount": "amount",
          "currency": "currency"
        },
        "staticExecution": { "action_type": "charge" }
      },
      "CreatePaymentLink": {
        "executionMapping": {
          "amount": "amount",
          "currency": "currency"
        },
        "staticExecution": { "action_type": "charge" }
      },
      "CreateCapture": {
        "executionMapping": {
          "amount_value": "amount",
          "amount_currency": "currency"
        },
        "staticExecution": { "action_type": "charge" }
      },
      "CreateSubscription": {
        "executionMapping": {
          "amount_value": "amount",
          "amount_currency": "currency"
        },
        "staticExecution": { "action_type": "subscribe" }
      },
      "UpdateSubscription": {
        "executionMapping": {},
        "staticExecution": { "action_type": "subscribe" }
      },
      "CancelSubscription": {
        "executionMapping": {},
        "staticExecution": { "action_type": "subscribe" }
      },
      "CreateCustomer": {
        "executionMapping": {},
        "staticExecution": { "action_type": "charge" }
      },
      "UpdateCustomer": {
        "executionMapping": {},
        "staticExecution": { "action_type": "charge" }
      },
      "CreateMandate": {
        "executionMapping": {},
        "staticExecution": { "action_type": "charge" }
      },
      "RevokeMandate": {
        "executionMapping": {},
        "staticExecution": { "action_type": "charge" }
      },
      "CreateWebhook": {
        "executionMapping": {},
        "staticExecution": { "action_type": "charge" }
      },
      "UpdateWebhook": {
        "executionMapping": {},
        "staticExecution": { "action_type": "charge" }
      }
    }
  },
  "templates": [
    {
      "name": "Monitor Payments",
      "description": "Read-only. View payments, balances, invoices, and transaction history.",
      "risk": "low",
      "mode": "automatic",
      "bounds": { "amount_max": "0", "amount_daily_max": "0", "amount_monthly_max": "0", "transaction_count_daily_max": "100" },
      "context": { "currency": "EUR", "action_type": "charge" },
      "intent": "Allow the agent to monitor payments and view transaction history. Read-only — no payments are created or modified.",
      "ttl": 2592000,
      "tags": ["read-only", "EUR", "100 ops/day"]
    },
    {
      "name": "Small Payments",
      "description": "Create payment links and process charges up to \u20ac50 per transaction.",
      "risk": "medium",
      "mode": "automatic",
      "bounds": { "amount_max": "50", "amount_daily_max": "200", "amount_monthly_max": "2000", "transaction_count_daily_max": "20" },
      "context": { "currency": "EUR", "action_type": "charge" },
      "intent": "Allow the agent to create payment links and process small charges for routine invoicing. Max \u20ac50 per transaction, \u20ac200 per day.",
      "ttl": 2592000,
      "tags": ["\u20ac50/tx", "\u20ac200/day", "20 ops/day"]
    },
    {
      "name": "Full Payment Management",
      "description": "Payments, refunds, and subscriptions. Every action requires your approval.",
      "risk": "high",
      "mode": "review",
      "bounds": { "amount_max": "1000", "amount_daily_max": "5000", "amount_monthly_max": "20000", "transaction_count_daily_max": "50" },
      "context": { "currency": "EUR", "action_type": "charge,refund,subscribe" },
      "intent": "Full payment management — create payments, issue refunds, manage subscriptions. Every write action requires human review before execution.",
      "ttl": 2592000,
      "tags": ["\u20ac1,000/tx", "\u20ac5,000/day", "review mode"]
    }
  ],
  "setupHint": "Use a test token (test_...) for development.",
  "setupGuide": [
    {
      "title": "Create a Mollie account",
      "description": "Sign up at mollie.com if you don't have an account yet.",
      "link": "https://my.mollie.com/dashboard/signup"
    },
    {
      "title": "Get your access token",
      "description": "Go to Settings > Developer > Access tokens in your Mollie dashboard. Create an Organization access token.",
      "link": "https://my.mollie.com/dashboard/developers/api-keys"
    },
    {
      "title": "Enter your token below",
      "description": "Paste your Access Token in the field below. Use a test token (test_...) for development."
    }
  ]
}
