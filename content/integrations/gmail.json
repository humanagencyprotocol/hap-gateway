{
  "id": "gmail",
  "name": "Gmail",
  "version": "1.0.0",
  "description": "Send, draft, and read email via Gmail",
  "icon": "mail",
  "profile": "email",
  "mcp": {
    "command": "npx",
    "args": ["-y", "@shinzolabs/gmail-mcp@latest"],
    "env": { "PORT": "0" }
  },
  "credentials": {
    "fields": [
      { "key": "clientId", "label": "Client ID", "type": "text", "placeholder": "From Google Cloud Console" },
      { "key": "clientSecret", "label": "Client Secret", "type": "password", "placeholder": "OAuth2 client secret" }
    ],
    "envMapping": {
      "CLIENT_ID": "clientId",
      "CLIENT_SECRET": "clientSecret",
      "REFRESH_TOKEN": "refreshToken"
    }
  },
  "oauth": {
    "authUrl": "https://accounts.google.com/o/oauth2/v2/auth",
    "tokenUrl": "https://oauth2.googleapis.com/token",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.modify",
      "https://www.googleapis.com/auth/gmail.send"
    ],
    "credentialKeys": { "clientId": "clientId", "clientSecret": "clientSecret" },
    "tokenStorage": "refreshToken",
    "extraParams": { "access_type": "offline", "prompt": "consent" }
  },
  "toolGating": {
    "default": {
      "executionMapping": {},
      "staticExecution": { "recipient_count": 0 }
    },
    "overrides": {
      "send_message": {
        "executionMapping": {
          "to": [
            { "field": "recipient_count", "transform": "length" },
            { "field": "allowed_recipients", "transform": "join" },
            { "field": "allowed_domains", "transform": "join_domains" }
          ]
        },
        "staticExecution": { "action_type": "send" }
      },
      "create_draft": {
        "executionMapping": {
          "to": [
            { "field": "recipient_count", "transform": "length" },
            { "field": "allowed_recipients", "transform": "join" },
            { "field": "allowed_domains", "transform": "join_domains" }
          ]
        },
        "staticExecution": { "action_type": "send" }
      },
      "send_draft": {
        "executionMapping": {},
        "staticExecution": { "recipient_count": 1, "action_type": "send" }
      },
      "list_messages": { "category": "read" },
      "get_message": { "category": "read" },
      "get_attachment": { "category": "read" },
      "list_drafts": { "category": "read" },
      "get_draft": { "category": "read" },
      "delete_draft": { "category": "read" },
      "list_labels": { "category": "read" },
      "get_profile": { "category": "read" }
    }
  },
  "setupHint": "Create OAuth credentials at Google Cloud Console.",
  "setupGuide": [
    {
      "title": "Create a Google Cloud project",
      "description": "Go to the Google Cloud Console and create a new project (or use an existing one).",
      "link": "https://console.cloud.google.com/projectcreate"
    },
    {
      "title": "Enable the Gmail API",
      "description": "In your project, go to APIs & Services > Library, search for 'Gmail API', and enable it.",
      "link": "https://console.cloud.google.com/apis/library/gmail.googleapis.com"
    },
    {
      "title": "Create OAuth credentials",
      "description": "Go to APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID. Choose 'Web application'. Add your gateway callback URL as an authorized redirect URI.",
      "link": "https://console.cloud.google.com/apis/credentials"
    },
    {
      "title": "Add the redirect URI",
      "description": "Under Authorized redirect URIs, add: http://localhost:7400/auth/oauth/gmail/callback (or your gateway URL)."
    },
    {
      "title": "Enter your credentials below",
      "description": "Copy the Client ID and Client Secret from your OAuth client and paste them below."
    }
  ]
}
